# Negentropy Perceives Configuration
# Copy this file to .env and customize the values

# Server Settings
NEGENTROPY_PERCEIVES_SERVER_NAME=data-extractor
# NEGENTROPY_PERCEIVES_SERVER_VERSION=auto  # 版本号自动从 pyproject.toml 读取，无需手动配置

# Transport Configuration
# NEGENTROPY_PERCEIVES_TRANSPORT_MODE=stdio  # Options: stdio (default), http, sse
# NEGENTROPY_PERCEIVES_HTTP_HOST=localhost   # Host for HTTP server (when using http/sse transport)
# NEGENTROPY_PERCEIVES_HTTP_PORT=8000        # Port for HTTP server (when using http/sse transport)
# NEGENTROPY_PERCEIVES_HTTP_PATH=/mcp        # Path for HTTP endpoint (when using http/sse transport)
# NEGENTROPY_PERCEIVES_HTTP_CORS_ORIGINS=*   # CORS origins for HTTP transport (when using http/sse transport)

# Negentropy Perceives Framework Settings
NEGENTROPY_PERCEIVES_CONCURRENT_REQUESTS=16
NEGENTROPY_PERCEIVES_DOWNLOAD_DELAY=1.0
NEGENTROPY_PERCEIVES_RANDOMIZE_DOWNLOAD_DELAY=true
NEGENTROPY_PERCEIVES_AUTOTHROTTLE_ENABLED=true
NEGENTROPY_PERCEIVES_AUTOTHROTTLE_START_DELAY=1.0
NEGENTROPY_PERCEIVES_AUTOTHROTTLE_MAX_DELAY=60.0
NEGENTROPY_PERCEIVES_AUTOTHROTTLE_TARGET_CONCURRENCY=1.0

# Browser Automation Settings
NEGENTROPY_PERCEIVES_ENABLE_JAVASCRIPT=false
NEGENTROPY_PERCEIVES_BROWSER_HEADLESS=true
NEGENTROPY_PERCEIVES_BROWSER_TIMEOUT=30

# Anti-Detection Settings
NEGENTROPY_PERCEIVES_USE_RANDOM_USER_AGENT=true
NEGENTROPY_PERCEIVES_DEFAULT_USER_AGENT="Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/120.0.0.0 Safari/537.36"

# Proxy Settings (optional)
NEGENTROPY_PERCEIVES_USE_PROXY=false
NEGENTROPY_PERCEIVES_PROXY_URL=

# Request Settings
NEGENTROPY_PERCEIVES_MAX_RETRIES=3
NEGENTROPY_PERCEIVES_REQUEST_TIMEOUT=30

# LLM Orchestration Settings (optional, for method="smart")
# NEGENTROPY_PERCEIVES_LLM_API_KEY=          # ZhipuAI API Key（也可用 ZHIPU_API_KEY 环境变量）
# NEGENTROPY_PERCEIVES_LLM_MODEL=zhipu/glm-5-plus-250414  # LiteLLM 模型标识
# NEGENTROPY_PERCEIVES_LLM_TEMPERATURE=0.1   # LLM 温度参数
# NEGENTROPY_PERCEIVES_LLM_MAX_TOKENS=4096   # LLM 最大输出 token
# NEGENTROPY_PERCEIVES_LLM_TIMEOUT=60.0      # LLM API 超时（秒）
# NEGENTROPY_PERCEIVES_LLM_MAX_RETRIES=2     # LLM API 重试次数

# Hardware Acceleration Settings
# NEGENTROPY_PERCEIVES_ACCELERATOR_DEVICE=auto        # auto, cpu, cuda (NVIDIA), mps (Apple Silicon), xpu (Intel)
# NEGENTROPY_PERCEIVES_ACCELERATOR_NUM_THREADS=4      # CPU 推理线程数

# Docling PDF Engine Settings (需安装 docling 可选依赖)
# NEGENTROPY_PERCEIVES_DOCLING_ENABLED=false           # 启用 Docling PDF 引擎
# NEGENTROPY_PERCEIVES_DOCLING_OCR_ENABLED=true        # 启用 OCR 识别
# NEGENTROPY_PERCEIVES_DOCLING_TABLE_EXTRACTION_ENABLED=true    # 启用表格提取
# NEGENTROPY_PERCEIVES_DOCLING_FORMULA_EXTRACTION_ENABLED=true  # 启用公式提取（MPS 上自动禁用以保持 GPU 加速）