# Data Extractor Configuration
# Copy this file to .env and customize the values

# Server Settings
DATA_EXTRACTOR_SERVER_NAME=data-extractor
# DATA_EXTRACTOR_SERVER_VERSION=auto  # 版本号自动从 pyproject.toml 读取，无需手动配置

# Transport Configuration
# DATA_EXTRACTOR_TRANSPORT_MODE=stdio  # Options: stdio (default), http, sse
# DATA_EXTRACTOR_HTTP_HOST=localhost   # Host for HTTP server (when using http/sse transport)
# DATA_EXTRACTOR_HTTP_PORT=8000        # Port for HTTP server (when using http/sse transport)
# DATA_EXTRACTOR_HTTP_PATH=/mcp        # Path for HTTP endpoint (when using http/sse transport)
# DATA_EXTRACTOR_HTTP_CORS_ORIGINS=*   # CORS origins for HTTP transport (when using http/sse transport)

# Data Extractor Framework Settings
DATA_EXTRACTOR_CONCURRENT_REQUESTS=16
DATA_EXTRACTOR_DOWNLOAD_DELAY=1.0
DATA_EXTRACTOR_RANDOMIZE_DOWNLOAD_DELAY=true
DATA_EXTRACTOR_AUTOTHROTTLE_ENABLED=true
DATA_EXTRACTOR_AUTOTHROTTLE_START_DELAY=1.0
DATA_EXTRACTOR_AUTOTHROTTLE_MAX_DELAY=60.0
DATA_EXTRACTOR_AUTOTHROTTLE_TARGET_CONCURRENCY=1.0

# Browser Automation Settings
DATA_EXTRACTOR_ENABLE_JAVASCRIPT=false
DATA_EXTRACTOR_BROWSER_HEADLESS=true
DATA_EXTRACTOR_BROWSER_TIMEOUT=30

# Anti-Detection Settings
DATA_EXTRACTOR_USE_RANDOM_USER_AGENT=true
DATA_EXTRACTOR_DEFAULT_USER_AGENT="Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/120.0.0.0 Safari/537.36"

# Proxy Settings (optional)
DATA_EXTRACTOR_USE_PROXY=false
DATA_EXTRACTOR_PROXY_URL=

# Request Settings
DATA_EXTRACTOR_MAX_RETRIES=3
DATA_EXTRACTOR_REQUEST_TIMEOUT=30

# LLM Orchestration Settings (optional, for method="smart")
# DATA_EXTRACTOR_LLM_API_KEY=          # ZhipuAI API Key（也可用 ZHIPU_API_KEY 环境变量）
# DATA_EXTRACTOR_LLM_MODEL=zhipu/glm-5-plus-250414  # LiteLLM 模型标识
# DATA_EXTRACTOR_LLM_TEMPERATURE=0.1   # LLM 温度参数
# DATA_EXTRACTOR_LLM_MAX_TOKENS=4096   # LLM 最大输出 token
# DATA_EXTRACTOR_LLM_TIMEOUT=60.0      # LLM API 超时（秒）
# DATA_EXTRACTOR_LLM_MAX_RETRIES=2     # LLM API 重试次数

# Hardware Acceleration Settings
# DATA_EXTRACTOR_ACCELERATOR_DEVICE=auto        # auto, cpu, cuda (NVIDIA), mps (Apple Silicon), xpu (Intel)
# DATA_EXTRACTOR_ACCELERATOR_NUM_THREADS=4      # CPU 推理线程数

# Docling PDF Engine Settings (需安装 docling 可选依赖)
# DATA_EXTRACTOR_DOCLING_ENABLED=false           # 启用 Docling PDF 引擎
# DATA_EXTRACTOR_DOCLING_OCR_ENABLED=true        # 启用 OCR 识别
# DATA_EXTRACTOR_DOCLING_TABLE_EXTRACTION_ENABLED=true    # 启用表格提取
# DATA_EXTRACTOR_DOCLING_FORMULA_EXTRACTION_ENABLED=true  # 启用公式提取（MPS 上自动禁用以保持 GPU 加速）